ROBOFLOW_API_KEY=replace_with_your_roboflow_api_key
ROBOFLOW_API_URL=https://serverless.roboflow.com
ROBOFLOW_WORKSPACE_NAME=your-workspace-name
ROBOFLOW_WORKFLOW_ID=your-workflow-id
ROBOFLOW_WORKFLOW_IMAGE_KEY=image
ROBOFLOW_MODEL_ID=
ROBOFLOW_CONFIDENCE_THRESHOLD=0.35
ROBOFLOW_TIMEOUT_SECONDS=45
ROBOFLOW_MAX_IMAGE_SIZE=640
ROBOFLOW_JPEG_QUALITY=72
ROBOFLOW_CACHE_SIZE=128

FABRIGUARD_FRAME_URL=http://127.0.0.1:8000/inspect/frame
CAMERA_INDEX=0
CAMERA_POLL_INTERVAL_MS=500
CAMERA_PROCESS_EVERY_NTH_FRAME=5
CAMERA_FRAME_WIDTH=640
CAMERA_JPEG_QUALITY=70
CAMERA_REQUEST_TIMEOUT_SECONDS=15
